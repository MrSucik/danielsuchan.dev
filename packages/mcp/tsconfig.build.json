{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "declaration": false,
    "sourceMap": true,
    "moduleResolution": "node",
    "module": "ESNext",
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["src/__tests__/**/*"]
}
